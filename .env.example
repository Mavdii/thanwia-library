# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ ADMIN ONLY - Never commit this key or expose it in browser
# This key bypasses Row Level Security and should only be used server-side
# For development, you can use it in admin pages, but in production,
# consider using Supabase Auth or a backend API
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Project Configuration
VITE_APP_NAME=مكتبة الثانوية
VITE_APP_URL=https://maktabat-thanawya.com
